# Database Configuration
# 格式: mysql://用户名:密码@主机名:端口/数据库名
# 如果密码包含特殊字符，请使用 URL 编码 (例如 @ -> %40)
DATABASE_URL=mysql://root:your_password_here@localhost:3306/gepei_db

# Auth Configuration
# JWT 签名密钥（必填，生产环境建议 32+ 位随机字符串）
JWT_SECRET=replace_with_strong_random_secret
# JWT 过期时间（可选，默认 7d）
JWT_EXPIRES_IN=7d

# Tencent Map Key (Required for LBS features)
VITE_TENCENT_MAP_KEY=your_tencent_map_key_here

# SMS Configuration (Aliyun Dypns)
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_SMS_TEMPLATE_CODE=your_sms_template_code

# Runtime Policy Configuration (non-sensitive)
# 日志时区（中国业务默认 Asia/Shanghai）
LOG_TIMEZONE=Asia/Shanghai
# 限流窗口（毫秒）
THROTTLE_WINDOW_MS=60000
# Auth 接口默认限流（每窗口每IP）
THROTTLE_AUTH_MAX=20
# /api/v1/auth/verification-code 限流（每窗口每IP）
THROTTLE_VERIFICATION_CODE_MAX=5
# 触发限流时返回消息
THROTTLE_MESSAGE=Too many requests, please try again later

# Payment/OpenID Provider Configuration
# mock | wechat
PAYMENT_PROVIDER=mock
OPENID_PROVIDER=mock

# Required when PAYMENT_PROVIDER=wechat
# 必须是公网 https 回调地址
WECHAT_NOTIFY_URL=https://your-domain.com/wechat/pay/notify
WECHAT_PAY_APP_ID=wx_your_pay_app_id
WECHAT_PAY_MCH_ID=your_mch_id
WECHAT_PAY_MCH_SERIAL_NO=your_mch_cert_serial_no
WECHAT_PAY_PRIVATE_KEY_PATH=/absolute/path/to/apiclient_key.pem
WECHAT_PAY_PLATFORM_SERIAL_NO=your_platform_cert_serial_no
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=/absolute/path/to/wechatpay_platform_pub.pem
WECHAT_PAY_API_V3_KEY=0123456789abcdef0123456789abcdef
# Optional
WECHAT_PAY_BASE_URL=https://api.mch.weixin.qq.com

# Required when OPENID_PROVIDER=wechat
WECHAT_OAUTH_APP_ID=wx_your_oauth_app_id
WECHAT_OAUTH_APP_SECRET=your_oauth_app_secret
